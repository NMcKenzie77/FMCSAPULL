# Railway provides this automatically when you attach a Postgres database.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional. Use any long random string. Required for write/import endpoints.
ADMIN_API_KEY=change-me

# Current DOT DataHub source used for new-carrier lead imports.
# Company Census is updated daily and the importer sorts USDOT descending so the newest registrations load first.
FMCSA_COMPANY_CENSUS_DATASET=az4n-8mr2

# Compatibility settings. The old carrier-daily ID is automatically redirected to Company Census.
FMCSA_CARRIER_DAILY_DATASET=az4n-8mr2
FMCSA_CARRIER_ALL_HISTORY_DATASET=u4i8-4m26

# Optional Socrata app token for higher API rate limits.
SOCRATA_APP_TOKEN=

# Keep the import small by default. Set higher after testing.
FMCSA_IMPORT_LIMIT=5000
FMCSA_IMPORT_SOURCE=company-census

# ARKON Insurance lead intake export.
DEFAULT_AGENCY_ID=invicta-capital-group
ARKON_WEBHOOK_URL=https://your-arkon-insurance-domain/api/integrations/fmcsa/leads
ARKON_WEBHOOK_SECRET=use-the-same-value-as-FMCSA_INGEST_SECRET

# Optional Google Sheet export target if you later add an Apps Script web endpoint.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Texas state registry enrichment.
# Get this from the Texas Comptroller public-data API registration flow.
# The code uses the official base URL by default; override only if Texas changes it.
TX_COMPTROLLER_API_KEY=
TX_COMPTROLLER_API_BASE_URL=https://api.comptroller.texas.gov/public-data/v1/public
TX_ENRICHMENT_LIMIT=25

# Reserved placeholders for future official/state adapters.
# Do not add values unless that state publishes/assigns an official API key.
FL_SUNBIZ_API_KEY=
GA_CORPORATIONS_API_KEY=
NC_SECRETARY_OF_STATE_API_KEY=
AZ_CORPORATION_COMMISSION_API_KEY=
TN_SECRETARY_OF_STATE_API_KEY=
