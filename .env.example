# Railway provides this automatically when you attach a Postgres database.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional. Use any long random string. Required for write/import endpoints.
ADMIN_API_KEY=change-me

# DOT DataHub Socrata endpoints.
FMCSA_CARRIER_DAILY_DATASET=6qg9-x4f8
FMCSA_CARRIER_ALL_HISTORY_DATASET=6eyk-hxee
FMCSA_COMPANY_CENSUS_DATASET=az4n-8mr2

# Keep daily import small by default. Set higher after testing.
FMCSA_IMPORT_LIMIT=5000
FMCSA_IMPORT_SOURCE=carrier-daily

# ARKON Insurance lead intake export.
DEFAULT_AGENCY_ID=invicta-capital-group
ARKON_WEBHOOK_URL=https://your-arkon-insurance-domain/api/integrations/fmcsa/leads
ARKON_WEBHOOK_SECRET=use-the-same-value-as-FMCSA_INGEST_SECRET

# Optional Google Sheet export target if you later add an Apps Script web endpoint.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

# Texas state registry enrichment. Store the real key in Railway, not in chat or git.
TX_COMPTROLLER_API_KEY=
TX_COMPTROLLER_API_URL=
TX_ENRICHMENT_LIMIT=25
