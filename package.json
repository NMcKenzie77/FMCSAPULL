{
  "name": "fmcsa-insurance-leads",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Railway service for importing FMCSA/DOT trucking insurance leads and scoring them for P&C, life, and health outreach.",
  "scripts": {
    "dev": "tsx watch --import ./src/portal.js src/server.ts",
    "build": "tsc",
    "start": "node --import ./dist/portal.js dist/index.js db:init && node --import ./dist/portal.js dist/server.js",
    "import": "tsx src/index.ts import",
    "db:init": "tsx src/index.ts db:init",
    "score:refresh": "tsx src/index.ts score:refresh",
    "safer:refresh": "tsx src/safety/runSaferRefresh.ts",
    "export:arkon": "tsx src/index.ts export:arkon",
    "export:sheets": "tsx src/index.ts export:sheets"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
